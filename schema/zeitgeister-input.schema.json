{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Zeitgeister Sender Input",
  "description": "The content-only JSON a sender AI returns before the local CLI creates and authenticates a capsule.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_goal",
    "project_ethos",
    "constraints",
    "decisions",
    "blockers",
    "next_steps",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1",
      "default": "1.1"
    },
    "project_goal": {
      "type": "string",
      "minLength": 1
    },
    "project_ethos": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision",
          "rationale"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claims": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "source_refs"],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "status": {"enum": ["confirmed", "unconfirmed", "inferred", "disputed"]},
          "source_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "transfer_status", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "transfer_status": {"enum": ["included", "missing", "external"]},
          "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
          "bundle_path": {"type": "string", "minLength": 1},
          "note": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"transfer_status": {"const": "included"}}},
            "then": {
              "properties": {
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            }
          }
        ]
      }
    },
    "provenance": {
      "type": "object"
    }
  }
}
